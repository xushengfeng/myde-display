{
  "name": "myde-display",
  "version": "0.1.0",
  "description": "Node native module for DRM rendering and screen management using Neon",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run build:rust && npm run build:ts",
    "build:rust": "cargo-cp-artifact -nc index.node -- cargo build --message-format=json-render-diagnostics",
    "build:rust:release": "cargo-cp-artifact -nc index.node -- cargo build --release --message-format=json-render-diagnostics",
    "build:ts": "vite build",
    "dev": "vite",
    "clean": "rm -rf dist index.node target",
    "install": "npm run build:rust:release",
    "postinstall": "npm run build:ts",
    "example:basic": "npx tsx examples/basic.ts",
    "example:animation": "npx tsx examples/animation.ts",
    "test:structure": "npx tsx test/structure.ts"
  },
  "keywords": [
    "drm",
    "rendering",
    "native",
    "neon",
    "rust",
    "display",
    "screen",
    "graphics"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "cargo-cp-artifact": "^0.1.9",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-plugin-dts": "^3.9.0",
    "tsx": "^4.15.0"
  },
  "files": [
    "dist",
    "index.node"
  ]
}